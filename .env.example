# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
SESSION_SECRET=please-change-me
SESSION_DB_FILE=sessions.sqlite
DB_FILE=app.sqlite

# Domain restriction (optional)
# Set to your company domain to restrict access (e.g., "example.com")
# Leave empty or set ALLOW_ANY_DOMAIN=true to allow any Google account
ALLOWED_DOMAIN=

# Set to true to allow any authenticated Google user (ignores ALLOWED_DOMAIN)
ALLOW_ANY_DOMAIN=false

# Single-user mode: only the first user who logs in can use the app
# Useful for personal deployments
SINGLE_USER_MODE=false

# OAuth 2.0 (Google Cloud Console > Credentials > OAuth client ID)
# These values must match the Web client you created in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The redirect URI must also be listed on the OAuth client.
# Update to https://meet.example.com/oauth2/callback (or similar) in production.
GOOGLE_CALLBACK_URL=http://localhost:3000/oauth2/callback

# Grace window (milliseconds) after a meeting is created during which
# visitors are redirected to it without checking Google. Covers the gap
# between the host clicking their link and actually joining the call.
MEET_WINDOW_MS=300000

# Maximum age (milliseconds) of a meeting record. After the grace window and
# up to this age, visitors are only redirected while the conference is
# actually live (checked via the Google Meet API). Default: 8 hours.
MEET_MAX_AGE_MS=28800000
